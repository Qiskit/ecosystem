{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Classification.toml",
  "type": "object",
  "required": ["category", "labels", "interfaces"],
  "properties": {
    "category": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "cure_period_in_days": {
            "type": "integer"
          },
          "icon": {
            "type": "string"
          }
        },
        "required": ["name", "description"]
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "cure_period_in_days": {
            "type": "integer"
          },
          "icon": {
            "type": "string"
          }
        },
        "required": ["name", "description"]
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["name", "description"]
      }
    }
  }
}

